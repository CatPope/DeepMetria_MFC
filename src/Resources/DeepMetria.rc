// DeepMetria.rc - MFC resource file

#include "resource.h"
#include "afxres.h"

// UTF-8 code page for Korean strings — MUST come after standard includes
#pragma code_page(65001)

// ============================================================
// 버전 정보
// ============================================================
VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "DeepMetria"
            VALUE "FileDescription",  "DeepMetria LLM 데이터 분석"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "DeepMetria"
            VALUE "LegalCopyright",   "Copyright (C) 2025 DeepMetria"
            VALUE "OriginalFilename", "DeepMetria.exe"
            VALUE "ProductName",      "DeepMetria"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x412, 1200  // 한국어 유니코드
    END
END

// ============================================================
// 메인 프레임 메뉴 (IDR_MAINFRAME)
// ============================================================
IDR_MAINFRAME MENU
BEGIN
    POPUP "파일(&F)"
    BEGIN
        MENUITEM "데이터 열기(&O)...\tCtrl+O",   ID_FILE_OPEN_DATA
        MENUITEM SEPARATOR
        POPUP "최근 파일(&R)"
        BEGIN
            MENUITEM "비어 있음",                ID_FILE_MRU_FILE1, GRAYED
        END
        MENUITEM SEPARATOR
        MENUITEM "종료(&X)",                     ID_APP_EXIT
    END
    POPUP "분석(&A)"
    BEGIN
        MENUITEM "새 질문(&N)...\tCtrl+Q",       ID_ANALYSIS_NEW_QUERY
    END
    POPUP "도구(&T)"
    BEGIN
        MENUITEM "설정(&S)...",                  ID_TOOLS_SETTINGS
        MENUITEM "내보내기(&E)...",              ID_TOOLS_EXPORT
    END
    POPUP "도움말(&H)"
    BEGIN
        MENUITEM "DeepMetria 정보(&A)...",       ID_HELP_ABOUT
    END
END

// ============================================================
// 액셀러레이터
// ============================================================
IDR_MAINFRAME ACCELERATORS
BEGIN
    "O",            ID_FILE_OPEN_DATA,   VIRTKEY, CONTROL
    "Q",            ID_ANALYSIS_NEW_QUERY, VIRTKEY, CONTROL
    VK_F1,          ID_HELP_ABOUT,       VIRTKEY
END

// ============================================================
// 툴바 (IDR_TOOLBAR)
// ============================================================
IDR_TOOLBAR TOOLBAR 16, 15
BEGIN
    BUTTON  ID_FILE_OPEN_DATA
    SEPARATOR
    BUTTON  ID_TOOLS_SETTINGS
    BUTTON  ID_TOOLS_EXPORT
    SEPARATOR
    BUTTON  ID_ANALYSIS_NEW_QUERY
END

// ============================================================
// About 다이얼로그 (IDD_ABOUTBOX)
// ============================================================
IDD_ABOUTBOX DIALOGEX 0, 0, 320, 150
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "DeepMetria 정보"
FONT 9, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    ICON            IDR_MAINFRAME, IDC_STATIC, 11, 11, 20, 20
    LTEXT           "DeepMetria",
                    IDC_STATIC, 40, 10, 119, 8, SS_NOPREFIX
    LTEXT           "버전 1.0.0",
                    IDC_STATIC_VERSION, 40, 25, 119, 8
    LTEXT           "LLM 기반 데이터 분석 데스크톱 애플리케이션",
                    IDC_STATIC, 40, 40, 240, 8
    LTEXT           "Copyright (C) 2025 DeepMetria",
                    IDC_STATIC_COPYRIGHT, 40, 55, 220, 8
    DEFPUSHBUTTON   "확인", IDOK, 130, 120, 60, 14
END

// ============================================================
// QueryInput 폼 다이얼로그 (IDD_QUERYINPUT_FORM)
// ============================================================
IDD_QUERYINPUT_FORM DIALOGEX 0, 0, 500, 60
STYLE DS_SETFONT | WS_CHILD | WS_VISIBLE
FONT 9, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    EDITTEXT        IDC_EDIT_QUERY,    4,  8, 380, 14, ES_AUTOHSCROLL
    PUSHBUTTON      "분석(&A)",        IDC_BTN_ANALYZE,   390,  6, 50, 18
    LTEXT           "",                IDC_STATIC_STATUS,   4, 30, 380,  8
    CONTROL         "",                IDC_PROGRESS_BAR, "msctls_progress32",
                    WS_CHILD | WS_VISIBLE, 4, 42, 380, 10
END

// ============================================================
// Settings 다이얼로그 (IDD_SETTINGS)
// ============================================================
IDD_SETTINGS DIALOGEX 0, 0, 280, 140
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "LLM 설정"
FONT 9, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    LTEXT           "Provider:",     IDC_STATIC,        10, 14, 45, 8
    COMBOBOX        IDC_COMBO_PROVIDER,                  60, 12, 100, 80,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "API Key:",      IDC_STATIC,        10, 36, 45, 8
    EDITTEXT        IDC_EDIT_API_KEY,                    60, 34, 205, 14,
                    ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Model:",        IDC_STATIC,        10, 58, 45, 8
    COMBOBOX        IDC_COMBO_MODEL,                     60, 56, 150, 80,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    PUSHBUTTON      "연결 테스트",   IDC_BTN_TEST,      60, 80, 70, 16

    DEFPUSHBUTTON   "확인",          IDOK,             130, 115, 60, 14
    PUSHBUTTON      "취소",          IDCANCEL,         200, 115, 60, 14
END

// ============================================================
// Export 다이얼로그 (IDD_EXPORT)
// ============================================================
IDD_EXPORT DIALOGEX 0, 0, 320, 180
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "내보내기"
FONT 9, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    LTEXT           "형식:",         IDC_STATIC,        10, 12, 30, 8
    COMBOBOX        IDC_COMBO_FORMAT,                    50, 10, 100, 80,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "저장 경로:",    IDC_STATIC,        10, 34, 40, 8
    EDITTEXT        IDC_EDIT_PATH,                       50, 32, 200, 14,
                    ES_AUTOHSCROLL | ES_READONLY
    PUSHBUTTON      "...",           IDC_BTN_BROWSE,    255, 31, 30, 16

    LTEXT           "너비:",         IDC_STATIC,        10, 58, 30, 8
    EDITTEXT        IDC_EDIT_WIDTH,                      50, 56, 50, 14,
                    ES_AUTOHSCROLL | ES_NUMBER
    CONTROL         "",              IDC_SPIN_WIDTH,    "msctls_updown32",
                    UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_AUTOBUDDY |
                    UDS_ARROWKEYS, 90, 56, 11, 14

    LTEXT           "높이:",         IDC_STATIC,        120, 58, 30, 8
    EDITTEXT        IDC_EDIT_HEIGHT,                     155, 56, 50, 14,
                    ES_AUTOHSCROLL | ES_NUMBER
    CONTROL         "",              IDC_SPIN_HEIGHT,   "msctls_updown32",
                    UDS_SETBUDDYINT | UDS_ALIGNRIGHT | UDS_AUTOBUDDY |
                    UDS_ARROWKEYS, 195, 56, 11, 14

    PUSHBUTTON      "내보내기",      IDC_BTN_EXPORT,    50, 85, 80, 16
    DEFPUSHBUTTON   "닫기",          IDCANCEL,          230, 155, 60, 14
END

// ============================================================
// FormatEditor 다이얼로그 (IDD_FORMAT_EDITOR)
// ============================================================
IDD_FORMAT_EDITOR DIALOGEX 0, 0, 300, 200
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "서식 편집"
FONT 9, "MS Shell Dlg 2", 400, 0, 0x1
BEGIN
    LTEXT           "차트 유형:",    IDC_STATIC,            10, 14, 45, 8
    COMBOBOX        IDC_COMBO_CHART_TYPE,                    60, 12, 100, 80,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "너비:",         IDC_STATIC,            10, 38, 30, 8
    CONTROL         "",              IDC_SLIDER_WIDTH,      "msctls_trackbar32",
                    TBS_AUTOTICKS | WS_TABSTOP, 45, 36, 170, 15
    EDITTEXT        IDC_EDIT_FMT_WIDTH,                     220, 37, 40, 14,
                    ES_AUTOHSCROLL | ES_NUMBER | ES_READONLY

    LTEXT           "높이:",         IDC_STATIC,            10, 60, 30, 8
    CONTROL         "",              IDC_SLIDER_HEIGHT,     "msctls_trackbar32",
                    TBS_AUTOTICKS | WS_TABSTOP, 45, 58, 170, 15
    EDITTEXT        IDC_EDIT_FMT_HEIGHT,                    220, 59, 40, 14,
                    ES_AUTOHSCROLL | ES_NUMBER | ES_READONLY

    LTEXT           "색상:",         IDC_STATIC,            10, 84, 30, 8
    PUSHBUTTON      "색상 선택...",  IDC_BTN_COLOR,          45, 82, 70, 16
    CTEXT           "",              IDC_STATIC_COLOR_PREVIEW, 125, 82, 30, 16,
                    SS_SUNKEN

    GROUPBOX        "미리보기",      IDC_STATIC,            10, 105, 280, 55
    CTEXT           "",              IDC_STATIC_PREVIEW,    20, 118, 260, 35,
                    SS_SUNKEN

    DEFPUSHBUTTON   "적용",          IDC_BTN_APPLY,        130, 172, 60, 16
    PUSHBUTTON      "취소",          IDC_BTN_FMT_CANCEL,   200, 172, 60, 16
END

// ============================================================
// 문자열 테이블
// ============================================================
STRINGTABLE
BEGIN
    IDR_MAINFRAME       "DeepMetria\n\nDeepMetria\n데이터 파일 (*.csv;*.xlsx)\n*.csv;*.xlsx\nDeepMetria.Document\nDeepMetria 문서"
    AFX_IDS_APP_TITLE   "DeepMetria"
    AFX_IDS_IDLEMESSAGE "준비"
END
